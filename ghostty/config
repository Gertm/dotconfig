# font-family = "BlexMono Nerd Font Mono"
#font-family = "CommitMono Nerd Font Mono"
#font-family = "DepartureMono Nerd Font"
font-family = "MonaspiceXe Nerd Font"
#font-family = "Px437 Philips :YES G"

font-style = "Regular"
font-size = 15
font-feature = -calt,+liga,+dlig
theme = /home/gert/.config/ghostty/themes/catppuccin-latte.conf
mouse-hide-while-typing = true
background-opacity = 0.95
keybind = global:super+escape=toggle_quick_terminal
quick-terminal-animation-duration = 0
# Host *
#    SetEnv TERM=xterm-256color
macos-option-as-alt = left

keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = alt+shift+left=goto_split:left
keybind = alt+shift+right=goto_split:right
